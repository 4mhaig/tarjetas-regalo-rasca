# MongoDB
MONGODB_URI=mongodb://localhost:27017/tarjetas-regalo
# Para MongoDB Atlas, usa: mongodb+srv://usuario:password@cluster.mongodb.net/tarjetas-regalo

# Server
PORT=3000
NODE_ENV=development

# Email (usa SendGrid o Resend)
EMAIL_SERVICE=gmail
EMAIL_USER=tu-email@gmail.com
EMAIL_PASSWORD=tu-contraseña-app
# Para SendGrid:
# SENDGRID_API_KEY=tu-api-key

# URL base de tu aplicación
BASE_URL=http://localhost:3000

# Expiración de tarjetas (en días)
CARD_EXPIRATION_DAYS=30
